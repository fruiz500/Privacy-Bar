{
  "manifest_version": 3,
  "name": "Privacy Bar",
  "version": "1.0.2",
  "permissions": [
    "sidePanel",
    "storage",
    "alarms",
    "activeTab",
    "scripting",
    "declarativeNetRequestWithHostAccess"
  ],
  "optional_permissions": [
    "contextMenus"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "safeview.html",
        "safeview.js"
      ],
      "matches": [
        "https://*/*",
        "http://*/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Privacy Bar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}